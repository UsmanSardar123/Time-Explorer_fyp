# ─────────────────────────────────────────────────────────────────────────────
# Time Explorer — Backend environment variables
# Copy this file to .env (never commit .env to git)
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development        # Set to "production" on Render / Railway

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
#
# DEVELOPMENT:
#   Place serviceAccountKey.json in backend/ (never commit it).
#   Leave FIREBASE_SERVICE_ACCOUNT_KEY unset — the file is used automatically.
#
# PRODUCTION (Render / Railway):
#   Do NOT upload serviceAccountKey.json to the server.
#   Instead, paste the entire JSON as a single-line string in the env var below.
#   How to get it: Firebase Console → Project Settings → Service Accounts → Generate new private key
#   How to format: minify the JSON to one line (no real newlines), then paste.
#   The \n characters inside private_key are fine — they are handled automatically.
#
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Development: comma-separated list of allowed browser origins
# Production:  set to * to allow all origins (Flutter mobile apps don't enforce CORS)
ALLOWED_ORIGINS=*
