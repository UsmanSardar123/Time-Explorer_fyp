# BACKEND ONLY — Node/Express server config.
# Flutter app does NOT use this file.
# Flutter uses lib/firebase_options.dart (generated by flutterfire configure).

PORT=5000
NODE_ENV=development

# Paste the full JSON content of your Firebase service account key as a single-line string
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
