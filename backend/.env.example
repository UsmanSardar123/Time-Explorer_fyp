# BACKEND ONLY — Node/Express server config.
# Flutter app does NOT use this file.
# Flutter uses lib/firebase_options.dart (generated by flutterfire configure).

PORT=5000
NODE_ENV=development

# Firebase credentials are loaded from serviceAccountKey.json (backend/ folder).
# Do NOT set FIREBASE_SERVICE_ACCOUNT_KEY here — the JSON file takes precedence.
# Download the file from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# NEVER commit serviceAccountKey.json to git.

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
